<?xml version="1.0"?>

<launch>

    <!-- Gazebo 模擬時間 -->
    <param name="/use_sim_time" value="false"/>

    <!-- 儲存好的地圖 -->
    <arg name="map_file"
         default="$(find my_car_description)/maps/my_map.yaml"/>

    

    <!-- 發布靜態地圖 -->
    <node pkg="map_server"
          type="map_server"
          name="map_server"
          args="$(arg map_file)"
          output="screen"/>

    <include file="$(find my_car_description)/launch/als_config.launch"/>

    
    <node pkg="rviz"
          type="rviz"
          name="rviz"
          args="-d $(find my_car_description)/rviz/car.rviz"
          output="screen"/>
    

          
</launch>