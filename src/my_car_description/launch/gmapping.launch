<?xml version="1.0"?>

<launch>
    <arg name="model"
        default="$(find my_car_description)/urdf/ackermann.urdf"/>
    <arg name="world"
        default="$(find my_car_description)/world/package.xml"/>

    <arg name="gui" default="false"/>
    <arg name="paused" default="false"/>
    <arg name="rviz" default="true"/>

    <param name="/use_sim_time" value="true"/>

    <param name="robot_description"
        textfile="$(arg model)"/>


        <!-- 載入 controller 設定 -->
    <rosparam command="load"
            file="$(find my_car_description)/config/controllers.yaml"/>

    <!-- 啟動 controllers -->
    <node pkg="controller_manager"
        type="spawner"
        name="controller_spawner"
        output="screen"
        args="
            joint_state_controller
            left_front_steering_controller
            right_front_steering_controller
            left_rear_wheel_controller
            right_rear_wheel_controller
        "/>

    <include file="$(find gazebo_ros)/launch/empty_world.launch">
        <arg name="world_name" value="$(arg world)"/>
        <arg name="gui" value="$(arg gui)"/>
        <arg name="paused" value="$(arg paused)"/>
        <arg name="use_sim_time" value="true"/>
    </include>

    <node pkg="gazebo_ros"
          type="spawn_model"
          name="spawn_ackermann_car"
          output="screen"
          args="-urdf
                -param robot_description
                -model my_car_ackermann
                -x 0
                -y 0
                -z 0.15"/>

    <node pkg="my_car_description"
        type="gazebo_odom.py"
        name="gazebo_odom_publisher"
        output="screen">

        <param name="model_name" value="my_car_ackermann"/>

        <param name="odom_topic" value="/odom"/>
        <param name="odom_frame" value="odom"/>
        <param name="base_frame" value="base_footprint"/>

        <!-- 系統內只能有一個節點發布這組 TF -->
        <param name="publish_tf" value="true"/>

        <!-- 將車子生成時的位置設為 odom 原點 -->
        <param name="reset_origin" value="true"/>

    </node>


    <!-- 全部系統只啟動這一個 -->
    <node pkg="robot_state_publisher"
          type="robot_state_publisher"
          name="robot_state_publisher"
          output="screen"/>



     <!-- GMapping -->
    <node pkg="gmapping"
          type="slam_gmapping"
          name="slam_gmapping"
          output="screen">

        <!-- Topic -->
        <remap from="scan" to="scan"/>

        <!-- TF -->
        <param name="map_frame" value="map"/>
        <param name="odom_frame" value="odom"/>
        <param name="base_frame" value="base_footprint"/>

        <!-- 地圖更新頻率 -->
        <param name="map_update_interval" value="2.0"/>

        <!-- 雷達有效距離，需小於雷達 max range -->
        <param name="maxUrange" value="11.5"/>
        <param name="maxRange" value="12.0"/>

        <!-- TF 容忍時間 -->
        <param name="transform_publish_period" value="0.05"/>
        <param name="tf_delay" value="0.1"/>

        <!-- 移動多少才更新掃描 -->
        <param name="linearUpdate" value="0.10"/>
        <param name="angularUpdate" value="0.05"/>
        <param name="temporalUpdate" value="0.5"/>

        <!-- 粒子數 -->
        <param name="particles" value="50"/>

        <!-- 掃描匹配參數 -->
        <param name="minimumScore" value="50"/>
        <param name="lskip" value="0"/>

        <!-- 地圖範圍 -->
        <param name="xmin" value="-20.0"/>
        <param name="ymin" value="-20.0"/>
        <param name="xmax" value="20.0"/>
        <param name="ymax" value="20.0"/>

        <!-- 地圖解析度，單位 m/cell -->
        <param name="delta" value="0.05"/>

        <!-- GMapping 常用參數 -->
        <param name="sigma" value="0.05"/>
        <param name="kernelSize" value="1"/>
        <param name="lstep" value="0.05"/>
        <param name="astep" value="0.05"/>
        <param name="iterations" value="5"/>

        <param name="lsigma" value="0.075"/>
        <param name="ogain" value="3.0"/>
        <param name="lskip" value="0"/>

        <param name="srr" value="0.1"/>
        <param name="srt" value="0.2"/>
        <param name="str" value="0.1"/>
        <param name="stt" value="0.2"/>

        <param name="linearThreshold" value="0.05"/>
        <param name="angularThreshold" value="0.05"/>
        <param name="resampleThreshold" value="0.5"/>

        <param name="llsamplerange" value="0.01"/>
        <param name="llsamplestep" value="0.01"/>
        <param name="lasamplerange" value="0.005"/>
        <param name="lasamplestep" value="0.005"/>

    </node>

    <node pkg="rviz"
          type="rviz"
          name="rviz"
          args="-d $(find my_car_description)/rviz/car.rviz"
          output="screen"/>

</launch>