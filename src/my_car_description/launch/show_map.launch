<?xml version="1.0"?>

<launch>

  <arg name="map_file"
       default="$(find my_car_description)/maps/my_map.yaml"/>

  <!-- 只顯示靜態地圖，不使用 Gazebo 時間 -->
  <param name="/use_sim_time" value="false"/>

  <node pkg="map_server"
        type="map_server"
        name="map_server"
        args="$(arg map_file)"
        output="screen"/>

  <node pkg="rviz"
        type="rviz"
        name="rviz"
        args="-d $(find my_car_description)/rviz/show_map.rviz"
        output="screen"/>

</launch>